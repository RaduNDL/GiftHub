rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    function userDocExists() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function currentUserRole() {
      return userDocExists() ? currentUserData().role : null;
    }

    function isEmployee() {
      return isSignedIn() && currentUserRole() == "employee";
    }

    match /users/{userId} {
      allow create: if isOwner(userId);
      allow read, update, delete: if isOwner(userId) || isEmployee();

      match /favorites/{favoriteId} { allow read, write: if isOwner(userId); }
      match /addresses/{addressId} { allow read, write: if isOwner(userId); }
      match /paymentMethods/{paymentMethodId} { allow read, write: if isOwner(userId); }

      match /shoppingCart/{cartId} {
        allow read, write: if isOwner(userId);
        match /items/{itemId} { allow read, write: if isOwner(userId); }
      }

      match /orders/{orderId} {
        allow create: if isOwner(userId);
        allow read: if isOwner(userId) || isEmployee();
        allow update: if isOwner(userId) || isEmployee();
        allow delete: if isOwner(userId);
      }

      match /notifications/{notificationId} {
        allow read, update, delete: if isOwner(userId);
        allow create: if isOwner(userId) || isEmployee();
      }
    }

    match /{path=**}/orders/{orderId} {
      allow read: if isSignedIn() &&
        (isEmployee() || request.auth.uid == resource.data.userId);
      allow update: if isEmployee();
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isEmployee();
    }

    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isEmployee();
    }
  }
}